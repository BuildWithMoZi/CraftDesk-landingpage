# Site URL — set to your live domain (no trailing slash).
# Custom domain example: https://craftdesk.in
# GitHub Pages example: https://buildwithmozi.github.io/CraftDesk-landingpage
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Leave empty when deploying to a custom domain root.
# For GitHub Pages project sites, use: /CraftDesk-landingpage
NEXT_PUBLIC_BASE_PATH=

# Google Search Console verification (optional — paste the content value only)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code

# Set to "true" only for static export builds (e.g. GitHub Pages).
# STATIC_EXPORT=true
